<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="captcha" method="upgrade">
	<name>plg_captcha_redeyed</name>
	<author>Redeyed Corporation</author>
	<creationDate>2026-06</creationDate>
	<copyright>Copyright (C) 2026 Redeyed Corporation. All rights reserved.</copyright>
	<license>MIT</license>
	<authorEmail>support@redeyed.com</authorEmail>
	<authorUrl>https://redeyed.com</authorUrl>
	<version>1.0.2</version>
	<description>PLG_CAPTCHA_REDEYED_XML_DESCRIPTION</description>
	<namespace path="src">Redeyed\Plugin\Captcha\Redeyed</namespace>

	<files>
		<folder plugin="redeyed">services</folder>
		<folder>src</folder>
		<folder>language</folder>
	</files>

	<languages folder="language">
		<language tag="en-GB">en-GB/plg_captcha_redeyed.ini</language>
		<language tag="en-GB">en-GB/plg_captcha_redeyed.sys.ini</language>
	</languages>

	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="site_key"
					type="text"
					label="PLG_CAPTCHA_REDEYED_FIELD_SITE_KEY_LABEL"
					description="PLG_CAPTCHA_REDEYED_FIELD_SITE_KEY_DESC"
					filter="string"
				/>
				<field
					name="secret_key"
					type="password"
					label="PLG_CAPTCHA_REDEYED_FIELD_SECRET_KEY_LABEL"
					description="PLG_CAPTCHA_REDEYED_FIELD_SECRET_KEY_DESC"
					autocomplete="off"
				/>
				<field
					name="base_url"
					type="url"
					label="PLG_CAPTCHA_REDEYED_FIELD_BASE_URL_LABEL"
					description="PLG_CAPTCHA_REDEYED_FIELD_BASE_URL_DESC"
					default="https://redeyed.com"
					filter="url"
				/>
				<field
					name="widget"
					type="list"
					label="PLG_CAPTCHA_REDEYED_FIELD_WIDGET_LABEL"
					description="PLG_CAPTCHA_REDEYED_FIELD_WIDGET_DESC"
					default=""
					filter="string"
				>
					<option value="">Adaptive (server default)</option>
					<option value="behavioral">Behavioral</option>
					<option value="checkbox">Checkbox</option>
					<option value="press_hold">Press &amp; Hold</option>
					<option value="image_pick">Image Pick</option>
				</field>
				<field
					name="theme"
					type="list"
					label="PLG_CAPTCHA_REDEYED_FIELD_THEME_LABEL"
					description="PLG_CAPTCHA_REDEYED_FIELD_THEME_DESC"
					default=""
					filter="string"
				>
					<option value="">Widget default</option>
					<option value="auto">Auto</option>
					<option value="light">Light</option>
					<option value="dark">Dark</option>
				</field>
				<field
					name="scheme"
					type="text"
					label="PLG_CAPTCHA_REDEYED_FIELD_SCHEME_LABEL"
					description="PLG_CAPTCHA_REDEYED_FIELD_SCHEME_DESC"
					filter="string"
				/>
				<field
					name="difficulty"
					type="text"
					label="PLG_CAPTCHA_REDEYED_FIELD_DIFFICULTY_LABEL"
					description="PLG_CAPTCHA_REDEYED_FIELD_DIFFICULTY_DESC"
					filter="string"
				/>
			</fieldset>
		</fields>
	</config>
</extension>
